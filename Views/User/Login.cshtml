@{
    ViewBag.Title = "Login";
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card shadow-lg p-4" style="width: 100%; max-width: 400px;">
        <h2 class="text-center text-primary mb-4">Login</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center">@ViewBag.Error</div>
        }

        @using (Html.BeginForm("Login", "User", FormMethod.Post))
        {
            <div class="form-group mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control form-control-lg" placeholder="Enter your email" required />
            </div>

            <div class="form-group mb-4">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required />
            </div>

            <div class="d-grid">
                <button type="submit" class="btn btn-primary btn-lg">Login</button>
            </div>
        }

        <div class="text-center mt-3">
            <p class="text-muted">Don't have an account? <a href="@Url.Action("Register", "User")" class="text-decoration-none">Register here</a></p>
        </div>
    </div>
</div>
