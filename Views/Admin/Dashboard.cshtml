@{
    ViewBag.Title = "Admin Dashboard";
}

<div class="container mt-5">
    <h2 class="text-center text-primary mb-5">Welcome, Admin!</h2>

    <div class="row g-4 justify-content-center">
        <div class="col-md-4">
            <div class="card text-white bg-dark shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">Manage Cars</h5>
                    @Html.ActionLink("Go", "Index", "Car", null, new { @class = "btn btn-outline-light" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-dark bg-warning shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">Manage Users</h5>
                    @Html.ActionLink("Go", "ManageUsers", "Admin", null, new { @class = "btn btn-outline-dark" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-secondary shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">View Bookings</h5>
                    @Html.ActionLink("Go", "ViewBookings", "Admin", null, new { @class = "btn btn-outline-light" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-dark bg-light shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">Manage Drivers</h5>
                    @Html.ActionLink("Go", "Index", "Drivers", null, new { @class = "btn btn-outline-primary" })
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-white bg-info shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">Manage Coupons</h5>
                    @Html.ActionLink("Go", "Coupons", "Admin", null, new { @class = "btn btn-outline-light" })
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-dark bg-light shadow h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center">
                    <h5 class="card-title mb-3">View Damage Reports</h5>
                    <a href="@Url.Action("AllDamageReports", "Admin")" class="btn btn-warning">Go</a>
                </div>
            </div>
        </div>

    </div>
</div>
