@model WebApplication2.Models.Driver

@{
    ViewBag.Title = "Delete Driver";
}

<div class="container mt-5">
    <h2 class="text-danger">Delete Driver</h2>

    <h3 class="text-warning">Are you sure you want to delete this driver?</h3>

    <div class="card shadow-sm">
        <div class="card-body">
            <h4 class="text-primary">Driver Details</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.ContactNumber)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.ContactNumber)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.LicenseNumber)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.LicenseNumber)
                </dd>
            </dl>

            <div class="d-flex justify-content-between">
                @using (Html.BeginForm())
                {
                    @Html.AntiForgeryToken()
                    <input type="submit" value="Delete" class="btn btn-danger" />
                }
                @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-secondary" })
            </div>
        </div>
    </div>
</div>
