@model WebApplication2.Models.Review

@{
    ViewBag.Title = "Leave a Review";
}

<h2>Leave a Review</h2>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @Html.HiddenFor(m => m.CarId)
    @Html.HiddenFor(m => m.UserId)

    <div class="form-group">
        @Html.LabelFor(m => m.Rating)
        @Html.DropDownListFor(m => m.Rating, new SelectList(new[] { 1, 2, 3, 4, 5 }), "Select Rating", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.Rating)
    </div>

    <div class="form-group">
        @Html.LabelFor(m => m.Comment)
        @Html.TextAreaFor(m => m.Comment, new { @class = "form-control", rows = 5 })
        @Html.ValidationMessageFor(m => m.Comment)
    </div>

    <button type="submit" class="btn btn-primary">Submit Review</button>
}
