@model IEnumerable<WebApplication2.Models.DamageReport>

<h2>All Reported Damages</h2>

<!-- Back Button -->
<a href="@Url.Action("Dashboard", "Admin")" class="btn btn-primary mb-3">Back to Dashboard</a>

<table class="table">
    <tr>
        <th>Customer</th>
        <th>Car</th>
        <th>Description</th>
        <th>Status</th>
        <th>Repair Cost</th>
        <th>Actions</th>
    </tr>
    @foreach (var report in Model)
    {
        <tr>
            <td>@report.Booking.User.FullName</td>
            <td>@report.Booking.Car.Make @report.Booking.Car.Model</td>
            <td>@report.Description</td>
            <td>@report.Status</td>
            <td>@(report.RepairCost.HasValue ? "₹" + report.RepairCost : "-")</td>
            <td>
                @if (report.Status == "Pending")
                {
                    <form method="post" action="@Url.Action("ProcessClaim", "Admin")">
                        @Html.Hidden("id", report.Id)
                        <input name="repairCost" type="number" step="0.01" placeholder="Cost" class="form-control mb-1" />
                        <button name="action" value="Approved" class="btn btn-success btn-sm">Approve</button>
                        <button name="action" value="Rejected" class="btn btn-danger btn-sm">Reject</button>
                    </form>
                }
                else
                {
                    <span class="badge bg-secondary">@report.Status</span>
                }
            </td>
        </tr>
    }
</table>
