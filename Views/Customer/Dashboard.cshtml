@{
    ViewBag.Title = "Customer Dashboard";
}

<div class="container mt-5">
    <div class="text-center mb-4">
        <h2 class="text-primary">Welcome to Your Dashboard</h2>
        <p class="text-muted">Access your bookings or browse available cars below.</p>
    </div>

    <div class="row justify-content-center g-4">
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-car-front-fill display-4 text-warning mb-3"></i>
                    <h5 class="card-title">Available Cars</h5>
                    <p class="card-text text-muted">View all cars ready for booking.</p>
                    @Html.ActionLink("View Available Cars", "AvailableCars", "Customer", null, new { @class = "btn btn-warning w-100" })
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="bi bi-calendar-check-fill display-4 text-info mb-3"></i>
                    <h5 class="card-title">My Bookings</h5>
                    <p class="card-text text-muted">Check your past and upcoming bookings.</p>
                    @Html.ActionLink("My Bookings", "MyBookings", "Customer", null, new { @class = "btn btn-info w-100" })
                </div>
            </div>
        </div>
    </div>
</div>
