@model IEnumerable<WebApplication2.Models.User>

@{
    ViewBag.Title = "Manage Users";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Manage Users</h2>
        @Html.ActionLink("Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-secondary" })
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                @if (user.Role == "Admin")
                                {
                                    <span class="badge bg-primary">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">User</span>
                                }
                            </td>
                            <td class="text-center">
                                @Html.ActionLink("Delete", "DeleteUser", "Admin", new { id = user.Id }, new
                                {
                                    @class = "btn btn-sm btn-outline-danger",
                                    onclick = "return confirm('Are you sure you want to delete this user?');"
                                })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
