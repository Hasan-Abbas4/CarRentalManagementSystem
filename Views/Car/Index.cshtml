@model IEnumerable<WebApplication2.Models.Car>

@{
    ViewBag.Title = "Manage Cars";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">Manage Cars</h2>
        @Html.ActionLink("Back to Dashboard", "Dashboard", "Admin", null, new { @class = "btn btn-secondary" })
    </div>

    <div class="mb-3 text-end">
        @Html.ActionLink("Add New Car", "Create", "Car", null, new { @class = "btn btn-success" })
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Car Model</th>
                        <th>Category</th>
                        <th>Price per Day</th>
                        <th>Available</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var car in Model)
                    {
                        <tr>
                            <td>@car.Model</td>
                            <td>@car.Category</td>
                            <td>@car.PricePerDay.ToString("C")</td>
                            <td>
                                @if (car.IsAvailable)
                                {
                                    <span class="badge bg-success">Yes</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">No</span>
                                }
                            </td>
                            <td class="text-center">
                                @Html.ActionLink("Edit", "Edit", new { id = car.Id }, new { @class = "btn btn-sm btn-outline-warning me-2" })
                                @Html.ActionLink("Delete", "Delete", new { id = car.Id }, new
                                {
                                    @class = "btn btn-sm btn-outline-danger",
                                    onclick = "return confirm('Are you sure you want to delete this car?');"
                                })
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
