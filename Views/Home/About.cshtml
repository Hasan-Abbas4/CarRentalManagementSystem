@{
    ViewBag.Title = "About";
}

<main aria-labelledby="title" class="container mt-5">
    <h2 id="title" class="text-primary mb-3">About CarRental</h2>

    <p class="lead text-muted">
        CarRental is your trusted partner for convenient, affordable, and reliable car rental services. We aim to make your travel experience smooth—whether it's a business trip, family vacation, or daily commute.
    </p>

    <div class="row mt-4">
        <div class="col-md-6">
            <h4 class="text-secondary">Who We Are</h4>
            <p>
                Founded in 2025, CarRental has rapidly grown into a customer-first rental platform, offering a wide range of vehicles to suit every need and budget. With easy online booking and real-time availability, we empower users to rent confidently.
            </p>
        </div>

        <div class="col-md-6">
            <h4 class="text-secondary">Our Mission</h4>
            <p>
                Our mission is to make vehicle rentals hassle-free, transparent, and accessible to everyone. We combine technology and customer service to ensure satisfaction, safety, and reliability at every step of the rental journey.
            </p>
        </div>
    </div>

    <div class="mt-4">
        <h4 class="text-secondary">Why Choose Us?</h4>
        <ul>
            <li>Wide selection of well-maintained vehicles</li>
            <li>Flexible rental periods and competitive pricing</li>
            <li>24/7 customer support and roadside assistance</li>
            <li>Real-time booking and cancellation</li>
        </ul>
    </div>
</main>
