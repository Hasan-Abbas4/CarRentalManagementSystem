@model IEnumerable<WebApplication2.Models.Coupon>

<div class="container mt-5">
    <h2 class="text-primary mb-4">Coupon Management</h2>

    <div class="mb-3">
        @Html.ActionLink("Create New Coupon", "CreateCoupon", "Admin", new { }, new { @class = "btn btn-primary btn-lg" })
    </div>

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Coupon Code</th>
                <th>Discount Percentage</th>
                <th>Expiry Date</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var coupon in Model)
            {
                <tr>
                    <td>@coupon.Code</td>
                    <td>@coupon.DiscountPercentage%</td>
                    <td>@coupon.ExpiryDate.ToShortDateString()</td>
                    <td>@(coupon.IsActive ? "Active" : "Inactive")</td>
                    <td>
                        @Html.ActionLink("Edit", "EditCoupon", "Admin", new { id = coupon.Id }, new { @class = "btn btn-warning btn-sm" })
                        |
                        @Html.ActionLink("Delete", "DeleteCoupon", "Admin", new { id = coupon.Id }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-4">
        @Html.ActionLink("Back to Admin Dashboard", "Dashboard", "Admin", new { @class = "btn btn-secondary btn-lg" })
    </div>
</div>
