
@model List<WebApplication2.Models.FavoriteCar>

<h2>Your Favorite Cars</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">
        @TempData["SuccessMessage"]
    </div>
}

@if (Model != null && Model.Any())
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Model</th>
                <th>Brand</th>
                <th>Price/Day</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Car.Model</td>
                    <td>@item.Car.Make</td>
                    <td>@item.Car.PricePerDay</td>
                    <td>
                        @Html.ActionLink("Remove", "Remove", "Favorite", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You haven't added any favorite cars yet.</p>
}
